{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "InvestBridge Platform",
  "uid": "investbridge-main",
  "tags": ["investbridge"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "query": "prometheus",
        "label": "Datasource",
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "investbridge-prometheus"
        },
        "hide": 0,
        "refresh": 1,
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "panels": [

    {
      "id": 1,
      "title": "Request Rate — All Services (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"dispatcher\"}[1m]))",
          "legendFormat": "dispatcher"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"auth-service\"}[1m]))",
          "legendFormat": "auth-service"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"idea-service\"}[1m]))",
          "legendFormat": "idea-service"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"deal-service\"}[1m]))",
          "legendFormat": "deal-service"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "id": 2,
      "title": "p95 Latency — All Services (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"dispatcher\"}[2m])) by (le)) * 1000",
          "legendFormat": "dispatcher p95"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"auth-service\"}[2m])) by (le)) * 1000",
          "legendFormat": "auth-service p95"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"idea-service\"}[2m])) by (le)) * 1000",
          "legendFormat": "idea-service p95"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"deal-service\"}[2m])) by (le)) * 1000",
          "legendFormat": "deal-service p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "id": 3,
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"dispatcher\",status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{job=\"dispatcher\"}[1m]))",
          "legendFormat": "dispatcher error rate"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"auth-service\",status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{job=\"auth-service\"}[1m]))",
          "legendFormat": "auth error rate"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"idea-service\",status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{job=\"idea-service\"}[1m]))",
          "legendFormat": "idea error rate"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"deal-service\",status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{job=\"deal-service\"}[1m]))",
          "legendFormat": "deal error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "id": 4,
      "title": "Dispatcher — Requests by Route (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(dispatcher_requests_total[1m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "id": 5,
      "title": "JVM Heap Used",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=\"dispatcher\"}",
          "legendFormat": "dispatcher heap"
        },
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=\"auth-service\"}",
          "legendFormat": "auth heap"
        },
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=\"idea-service\"}",
          "legendFormat": "idea heap"
        },
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=\"deal-service\"}",
          "legendFormat": "deal heap"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "id": 6,
      "title": "Dispatcher — Avg Request Duration by Route (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(dispatcher_request_duration_ms_sum[2m])) by (route) / sum(rate(dispatcher_request_duration_ms_count[2m])) by (route)",
          "legendFormat": "{{route}} avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },

    {
      "id": 7,
      "title": "Total Requests (last 5m)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(http_server_requests_seconds_count{job=\"dispatcher\"}[5m]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" }
    },

    {
      "id": 8,
      "title": "Active Threads — Dispatcher",
      "type": "stat",
      "gridPos": { "x": 6, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"dispatcher\"}",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" }
    },

    {
      "id": 9,
      "title": "Uptime — Dispatcher (s)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "process_uptime_seconds{job=\"dispatcher\"}",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" }
    },

    {
      "id": 10,
      "title": "CPU Usage — All Services",
      "type": "stat",
      "gridPos": { "x": 18, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "avg(process_cpu_usage{job=\"dispatcher\"}) * 100",
          "legendFormat": "dispatcher"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" }
    }

  ]
}
