# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values
#   cp .env.example .env
#
# .env is in .gitignore — it will NEVER be committed to GitHub
# .env.example IS committed — it shows teammates what vars are needed
# ─────────────────────────────────────────────────────────────

# JWT signing secret — must be at least 32 characters long
# Generate one with: openssl rand -base64 32
JWT_SECRET=change-this-to-a-random-32-char-secret-string

# OpenAI API key 
OPENAI_API_KEY=sk-your-openai-key-here
