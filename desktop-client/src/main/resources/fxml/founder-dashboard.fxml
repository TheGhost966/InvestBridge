<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="dashboard-root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.platform.desktop.view.controller.FounderDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="top-bar">
            <padding><Insets top="12" right="20" bottom="12" left="20"/></padding>
            <Label text="InvestBridge" styleClass="top-bar-title"/>
            <Label text="·"            styleClass="top-bar-sep"/>
            <Label text="Founder"      styleClass="top-bar-role founder"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="identityLabel" styleClass="muted-label"/>
            <Button text="Logout" onAction="#onLogout" styleClass="ghost-button"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <!-- Toolbar -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="My Ideas" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Refresh"   onAction="#onRefresh" styleClass="ghost-button"/>
                <Button text="+ New idea" onAction="#onNewIdea" styleClass="primary-button"/>
            </HBox>

            <Label fx:id="statusLabel" styleClass="muted-label" text=""/>

            <!-- Idea list (cards stack vertically) -->
            <ScrollPane fitToWidth="true" styleClass="card-scroll" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="ideaList" spacing="12">
                        <padding><Insets top="4" right="2" bottom="20" left="2"/></padding>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
