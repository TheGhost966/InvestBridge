<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="auth-root"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.platform.desktop.view.controller.RegisterController">

    <VBox alignment="CENTER" spacing="14" maxWidth="420" styleClass="auth-card">
        <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

        <Label text="InvestBridge"          styleClass="app-title"/>
        <Label text="Create your account"   styleClass="app-subtitle"/>

        <VBox spacing="6">
            <Label text="Email" styleClass="field-label"/>
            <TextField fx:id="emailField" promptText="you@example.com"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" promptText="min. 8 characters"/>
        </VBox>

        <VBox spacing="6">
            <Label text="I am a" styleClass="field-label"/>
            <ComboBox fx:id="roleBox" maxWidth="Infinity" promptText="Select your role"/>
            <Label text="Founders submit ideas; investors make offers; admins verify."
                   styleClass="muted-label" wrapText="true"/>
        </VBox>

        <Label fx:id="statusLabel" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

        <Button fx:id="registerButton"
                text="Create account"
                onAction="#onRegister"
                defaultButton="true"
                maxWidth="Infinity"
                styleClass="primary-button"/>

        <HBox alignment="CENTER" spacing="4">
            <Label text="Already registered?" styleClass="muted-label"/>
            <Hyperlink text="Sign in" onAction="#onGoToLogin"/>
        </HBox>

        <Region VBox.vgrow="ALWAYS"/>
    </VBox>
</StackPane>
